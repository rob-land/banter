"""Build-time constants — generated by Meson from const.py.in.

@APP_ID@, @APP_NAME@, @VERSION@, @PKGDATADIR@, @LOCALEDIR@ are
substituted at install time. Don't edit const.py directly; change
const.py.in or the meson configuration.
"""

APP_ID     = @APP_ID@
APP_NAME   = @APP_NAME@
VERSION    = @VERSION@
PKGDATADIR = @PKGDATADIR@
LOCALEDIR  = @LOCALEDIR@
