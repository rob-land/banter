{
  "_comment": "DRAFT Flathub-side manifest. NOT used by build-all.sh — that picks up land.rob.banter.json next to this file. When submitting to Flathub, copy this file's contents into the flathub/land.rob.banter repo. Keep this in sync with land.rob.banter.json — only the 'banter' module's sources block should differ.",

  "app-id": "land.rob.banter",
  "runtime": "org.gnome.Platform",
  "runtime-version": "50",
  "sdk": "org.gnome.Sdk",
  "command": "banter",

  "add-extensions": {
    "org.freedesktop.Platform.ffmpeg-full": {
      "version": "25.08",
      "directory": "lib/ffmpeg",
      "add-ld-path": ".",
      "no-autodownload": false,
      "autodelete": false
    }
  },

  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--socket=pulseaudio",
    "--device=dri",
    "--talk-name=org.freedesktop.Notifications",
    "--talk-name=org.freedesktop.portal.Background",
    "--talk-name=org.freedesktop.secrets"
  ],

  "cleanup": [
    "/include",
    "/lib/pkgconfig",
    "/man",
    "/share/doc",
    "/share/gtk-doc",
    "*.la",
    "*.a"
  ],

  "cleanup-commands": [
    "mkdir -p /app/lib/ffmpeg"
  ],

  "modules": [
    {
      "name": "blueprint-compiler",
      "buildsystem": "meson",
      "cleanup": ["*"],
      "sources": [
        {
          "type": "git",
          "url": "https://gitlab.gnome.org/jwestman/blueprint-compiler.git",
          "tag": "v0.16.0"
        }
      ]
    },
    {
      "name": "banter",
      "buildsystem": "meson",
      "config-opts": [],
      "sources": [
        {
          "type": "git",
          "url": "https://codeberg.org/robland/banter.git",
          "tag": "v0.1.0",
          "commit": "ce5adb2f389403447eeb06f0ca22fb27b4dc4090"
        }
      ]
    }
  ]
}
