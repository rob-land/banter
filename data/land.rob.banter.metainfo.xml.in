<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>land.rob.banter</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <name>Banter</name>
  <summary>Unofficial GroupMe client for GNOME</summary>

  <description>
    <p>
      Banter is an <em>unofficial</em> client for GroupMe using GTK4 / libadwaita
      to be usable on Linux desktops or mobile devices.
    </p>
    <p>
      It is not affiliated with or endorsed by GroupMe or Microsoft in any
      way. The app talks to GroupMe's public REST and WebSocket APIs the
      same way the official web client does, with an OAuth sign-in flow
      that never stores a password.
    </p>
    <p>
      Mirroring the official clients, conversations live in a single sidebar
      with groups and DMs mixed together, sorted by recent activity. Messages
      stream in via WebSocket push, drafts persist across chat switches, and
      the UI follows the system colour scheme with a layout that collapses
      cleanly to phone widths.
    </p>
    <ul>
      <li>Real-time messaging via WebSocket push</li>
      <li>Create and edit groups and start direct messages with group members</li>
      <li>Emoji reactions, polls, @-mentions, edit / delete, and in-chat search</li>
      <li>Image, video, voice, and file attachments with inline playback</li>
      <li>Group gallery with albums and member management</li>
      <li>OAuth sign-in via the system browser</li>
      <li>Adaptive layout that works for desktop GNOME or phones running Phosh</li>
    </ul>
  </description>

  <launchable type="desktop-id">land.rob.banter.desktop</launchable>

  <screenshots>
    <screenshot type="default">
      <caption>Group chat with poll, @-mentions, and reactions</caption>
      <image>https://raw.githubusercontent.com/rob-land/banter/main/data/screenshots/desktop-park-day-crew-light.png</image>
    </screenshot>
    <screenshot>
      <caption>Adaptive layout — group chat on a Linux phone</caption>
      <image>https://raw.githubusercontent.com/rob-land/banter/main/data/screenshots/phone-castle-sleepover-dark.png</image>
    </screenshot>
    <screenshot>
      <caption>Direct messages with emoji reactions, on a phone</caption>
      <image>https://raw.githubusercontent.com/rob-land/banter/main/data/screenshots/phone-mickey-hayes-dm-dark.png</image>
    </screenshot>
    <screenshot>
      <caption>Group conversation with stacked reactions</caption>
      <image>https://raw.githubusercontent.com/rob-land/banter/main/data/screenshots/desktop-castle-sleepover-light.png</image>
    </screenshot>
    <screenshot>
      <caption>Contacts list and the profile editor sheet</caption>
      <image>https://raw.githubusercontent.com/rob-land/banter/main/data/screenshots/phone-contacts-edit-profile-light.png</image>
    </screenshot>
  </screenshots>

  <url type="homepage">https://github.com/rob-land/banter</url>
  <url type="bugtracker">https://github.com/rob-land/banter/issues</url>
  <url type="vcs-browser">https://github.com/rob-land/banter</url>

  <developer id="land.rob">
    <name>Rob Daniel</name>
  </developer>

  <branding>
    <color type="primary" scheme_preference="light">#a4c8f0</color>
    <color type="primary" scheme_preference="dark">#1a5fb4</color>
  </branding>

  <releases>
    <release version="0.1.0" date="2026-05-01">
      <description>
        <p>First public release. Highlights:</p>
        <ul>
          <li>Real-time group chats and direct messages, unified in one sidebar</li>
          <li>Create and edit groups and start direct messages with group members</li>
          <li>Compose with @-mention autocomplete, drafts, and quote-reply</li>
          <li>Emoji reactions, polls, edit or delete messages, and in-chat search</li>
          <li>Image, video, voice, and file attachments</li>
          <li>Voice messages and videos play inline</li>
          <li>Group gallery with albums</li>
          <li>Group member, settings, event, and poll management</li>
          <li>OAuth sign-in via the system browser</li>
          <li>Desktop notifications and per-conversation mute</li>
          <li>Adaptive layout that works for desktop GNOME or phones running Phosh</li>
        </ul>
      </description>
    </release>
  </releases>

  <content_rating type="oars-1.1">
    <content_attribute id="social-chat">intense</content_attribute>
    <content_attribute id="social-info">mild</content_attribute>
  </content_rating>

  <requires>
    <display_length compare="ge">360</display_length>
  </requires>
  <recommends>
    <control>keyboard</control>
    <control>pointing</control>
    <control>touch</control>
  </recommends>
</component>
