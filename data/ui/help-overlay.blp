using Gtk 4.0;

ShortcutsWindow help_overlay {
  modal: true;

  ShortcutsSection {
    section-name: "main";
    visible: true;

    ShortcutsGroup {
      title: C_("shortcut window", "General");

      ShortcutsShortcut {
        accelerator: "<ctrl>f";
        title: C_("shortcut window", "Search the current chat");
      }

      ShortcutsShortcut {
        accelerator: "<ctrl>question";
        title: C_("shortcut window", "Show keyboard shortcuts");
      }

      ShortcutsShortcut {
        accelerator: "<ctrl>q";
        title: C_("shortcut window", "Quit");
      }
    }
  }
}
