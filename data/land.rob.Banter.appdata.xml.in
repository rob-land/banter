<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>land.rob.Banter</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <name>Banter</name>
  <summary>GroupMe client for GNOME</summary>

  <description>
    <p>
      Banter is a native GNOME client for GroupMe, built with GTK4 and
      libadwaita. It supports group chats, direct messages, reactions,
      image sharing, member management, and real-time push notifications
      via the GroupMe WebSocket API.
    </p>
    <ul>
      <li>Real-time messages via WebSocket push</li>
      <li>Emoji reactions with tooltips and details</li>
      <li>Image gallery and photo sharing</li>
      <li>Group settings, muting, and member management</li>
      <li>Adaptive layout for desktop and mobile</li>
    </ul>
  </description>

  <launchable type="desktop-id">land.rob.Banter.desktop</launchable>

  <url type="homepage">https://codeberg.org/robland/banter</url>
  <url type="bugtracker">https://codeberg.org/robland/banter/issues</url>
  <url type="vcs-browser">https://codeberg.org/robland/banter</url>

  <developer id="land.rob">
    <name>Rob Daniel</name>
  </developer>

  <branding>
    <color type="primary" scheme_preference="light">#a4c8f0</color>
    <color type="primary" scheme_preference="dark">#1a5fb4</color>
  </branding>

  <releases>
    <release version="0.1.0" date="2026-05-01">
      <description>
        <p>Initial release.</p>
      </description>
    </release>
  </releases>

  <content_rating type="oars-1.1">
    <content_attribute id="social-chat">intense</content_attribute>
    <content_attribute id="social-info">mild</content_attribute>
  </content_rating>

  <requires>
    <display_length compare="ge">360</display_length>
  </requires>
  <recommends>
    <control>keyboard</control>
    <control>pointing</control>
    <control>touch</control>
  </recommends>
</component>
