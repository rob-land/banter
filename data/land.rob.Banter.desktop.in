[Desktop Entry]
Name=Banter
Comment=GroupMe client for GNOME
Exec=banter %u
Icon=land.rob.Banter
Terminal=false
Type=Application
Categories=Network;InstantMessaging;Chat;
Keywords=GroupMe;chat;messaging;groups;
StartupNotify=true
StartupWMClass=banter
X-GNOME-UsesNotifications=true
MimeType=x-scheme-handler/banter;
